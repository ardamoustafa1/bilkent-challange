# Kök proje – örnek ortam değişkenleri
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun.
# .env dosyasını Git'e eklemeyin.

# Backend (backend/.env)
# PORT=3001

# Frontend (frontend/.env)
# VITE_API_URL=http://localhost:3001

# Vercel deploy (Vercel Dashboard'da ayarlanır)
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...
