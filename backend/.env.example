# Backend API – ortam değişkenleri
# Bu dosyayı .env olarak kopyalayın.

# Sunucu portu (varsayılan: 3001)
PORT=3001

# İsteğe bağlı: CORS izin verilen origin (virgülle ayrılmış; boş = tümü)
# CORS_ORIGIN=http://localhost:5173,https://myapp.vercel.app

# Kullanıcı hesapları (varsayılanlar aşağıdadır; production'da değiştirin)
# ADMIN_EMAIL=admin@biltek.k12.tr
# ADMIN_PASS=Biltek2026!
# ADMIN_NAME=Admin
# JUDGE_EMAIL=hakem@biltek.k12.tr
# JUDGE_PASS=Biltek2026!
# JUDGE_NAME=Hakem
# VISITOR_EMAIL=misafir@biltek.k12.tr
# VISITOR_PASS=Biltek2026!
# VISITOR_NAME=Ziyaretçi

# Veri dizini (varsayılan: ./data)
# DATA_DIR=./data

